# Multi-stage build for system-b
FROM maven:3.9-eclipse-temurin-21 AS builder

WORKDIR /app
COPY . .
RUN mvn clean package -pl system-b -am -DskipTests

FROM eclipse-temurin:21-jre

WORKDIR /app
COPY --from=builder /app/system-b/target/system-b-1.0.0.jar app.jar

EXPOSE 3006

ENTRYPOINT ["java", "-jar", "app.jar"]
